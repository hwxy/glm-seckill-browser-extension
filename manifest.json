{
  "manifest_version": 3,
  "name": "智抢",
  "version": "6.0",
  "description": "匹配指定请求并重定向到另一个地址",
  "permissions": ["storage", "scripting", "webNavigation", "declarativeNetRequest", "alarms", "cookies"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
